# Vercel / Production Environment Variables Template
# Copy these values to: Vercel Project Settings > Environment Variables
# Set scope to "Production" for prod-only vars, "Preview" for staging
#
# ⚠️  NEVER commit real values. This file only contains placeholders.

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://vwdgzyknnoslungagmhx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_production_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://inhumans.io

# ─── Zerodha (Production Kite Connect App) ───────────────────────────────────
ZERODHA_API_KEY=your_production_zerodha_api_key
ZERODHA_API_SECRET=your_production_zerodha_api_secret
ZERODHA_REDIRECT_URI=https://inhumans.io/api/brokers/zerodha/callback

# ─── Security & Encryption (Generate fresh values for prod!) ─────────────────
# Use: node -e "require('crypto').randomBytes(32).toString('hex')|tee -a .env"
BROKER_OAUTH_STATE_SECRET=generate_64_char_hex_secret_for_production
BROKER_TOKEN_ENCRYPTION_KEY=generate_64_char_hex_secret_for_production

# ─── Webhook Secrets ─────────────────────────────────────────────────────────
BROKER_WEBHOOK_SECRET=generate_strong_secret_for_production
COPY_TRADE_WEBHOOK_SECRET=generate_strong_secret_for_production
PUSH_DISPATCH_SECRET=generate_strong_secret_for_production

# ─── Razorpay ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_production_razorpay_key_id
RAZORPAY_KEY_SECRET=your_production_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_production_razorpay_webhook_secret

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAILS=ops@inhumans.io

# ─── Web Push Notifications ──────────────────────────────────────────────────
