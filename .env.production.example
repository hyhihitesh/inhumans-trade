NEXT_PUBLIC_VAPID_PUBLIC_KEY=BCF-doMkkvlSOdwReEoljiCg4DVG4_C9utu28rJ5tpMdRtcq4114-GquPsa6I-JgDn2OHOuEg30JnOUkw7Qt6QE
VAPID_PRIVATE_KEY=3tAIgGxspPLfQaaFRHzdLRf5b4HNb_7rk9NxdqfqtZc
